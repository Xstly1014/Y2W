# ===== LLM Provider =====
# OpenAI-compatible API (works with OpenAI / DeepSeek / Moonshot / Zhipu etc.)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ===== Embedding =====
# Two providers supported:
#   * openai — OpenAI-compatible embeddings API (needs a token with embedding access).
#   * local  — sentence-transformers model loaded in-process (works offline).
# Default to local because most LLM-only API tokens don't grant embedding access.
EMBEDDING_MODEL_NAME=local:BAAI/bge-small-zh-v1.5
EMBEDDING_PROVIDER=local

# ===== RAG / Vector store =====
VECTOR_STORE_DIR=./data/vectorstore
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=3

# ===== Memory =====
SHORT_TERM_MEMORY_MAX_MESSAGES=20
LONG_TERM_MEMORY_COLLECTION=long_term_memory

# ===== MCP =====
MCP_SERVER_URL=

# ===== Evaluation =====
EVAL_DATASET_PATH=./data/eval/eval_cases.yaml
EVAL_OUTPUT_DIR=./data/eval/results

# ===== Data Flywheel =====
BADCASE_STORE_PATH=./data/flywheel/badcases.jsonl
GOODCASE_STORE_PATH=./data/flywheel/goodcases.jsonl

# ===== Post Training =====
POST_TRAIN_OUTPUT_DIR=./data/post_training

# ===== Business Platform (cross-border e-commerce SaaS) =====
# Mock e-commerce platform base URL (Shopify/Shopee stand-in).
MOCK_PLATFORM_BASE_URL=http://127.0.0.1:8001
# Default tenant id used when no X-Tenant-Id header is supplied (demo only).
DEFAULT_TENANT_ID=demo-tenant
# Tenant-aware RAG collection name prefix. Real collection = f"{prefix}_{tenant_id}".
KB_COLLECTION_PREFIX=kb
# FastAPI service port (user-facing + admin UI).
API_PORT=8000
# Mock e-commerce platform port.
MOCK_PLATFORM_PORT=8001

# ===== E-commerce Platform (port 8002, Vue 3 SPA + PostgreSQL) =====
# Requires PostgreSQL 16+ installed locally.
# DSN format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
ECOMMERCE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/ecommerce
ECOMMERCE_DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ecommerce
ECOMMERCE_PORT=8002
ECOMMERCE_HOST=127.0.0.1
ECOMMERCE_AGENT_API_URL=http://127.0.0.1:8000
# Set ECOMMERCE_SKIP=1 to skip the e-commerce service in scripts/run_all.py
# (useful when PostgreSQL isn't installed yet).
# ECOMMERCE_SKIP=1
